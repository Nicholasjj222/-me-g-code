using System;
using System.IO;
using System.Security.Cryptography;

class BackupSystem
{
    static void Main(string[] args)
    {
        Console.WriteLine("=== Local Backup System ===");

        Console.Write("Source folder: ");
        string source = Console.ReadLine();

        Console.Write("Backup folder: ");
        string backup = Console.ReadLine();

        if (!Directory.Exists(source))
        {
            Console.WriteLine("Source folder not found.");
            return;
        }

        if (!Directory.Exists(backup))
            Directory.CreateDirectory(backup);

        SyncFolders(source, backup);

        Console.WriteLine("Backup complete.");
    }

    static void SyncFolders(string source, string backup)
    {
        foreach (var file in Directory.GetFiles(source, "*", SearchOption.AllDirectories))
        {
            string relativePath = Path.GetRelativePath(source, file);
            string backupFile = Path.Combine(backup, relativePath);

            string backupDir = Path.GetDirectoryName(backupFile);
            if (!Directory.Exists(backupDir))
                Directory.CreateDirectory(backupDir);

            if (!File.Exists(backupFile) || !FilesAreEqual(file, backupFile))
            {
                File.Copy(file, backupFile, true);
                Console.WriteLine($"Copied: {relativePath}");
            }
        }
    }

    static bool FilesAreEqual(string file1, string file2)
    {
        using (var md5 = MD5.Create())
        using (var stream1 = File.OpenRead(file1))
        using (var stream2 = File.OpenRead(file2))
        {
            byte[] hash1 = md5.ComputeHash(stream1);
            byte[] hash2 = md5.ComputeHash(stream2);

            return StructuralComparisons.StructuralEqualityComparer.Equals(hash1, hash2);
        }
    }
}